# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ── Banco de dados (PostgreSQL) ───────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:senha@localhost:5432/rastro"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"

# ── Webhook (pagamentos) ──────────────────────────────────────────────────────
# Stripe: use o Signing Secret do dashboard (whsec_...)
# Asaas/PagSeguro: gere um token aleatório e configure no painel do provedor
# Em dev sem Stripe: qualquer string serve (ex: "dev-secret-local")
WEBHOOK_SECRET="troque-por-seu-webhook-secret"

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Deixe vazio para usar localStorage (modo offline)
# Defina para conectar ao backend: VITE_API_URL="http://localhost:4000"
VITE_API_URL=
